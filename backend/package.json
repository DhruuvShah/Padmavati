{
  "name": "padmavati-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@sparticuz/chromium": "^148.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "puppeteer-core": "^25.0.4",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.0",
    "@types/puppeteer-core": "^5.4.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "node-domexception": "npm:domexception@^4.0.0"
  }
}
